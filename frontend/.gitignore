# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
/pnpm-lock.yaml

# testing
/coverage

# next.js
/.next/
/out/

# NOTE: `/public/data/` is committed. It holds the static JSON
# snapshot the Pages build ships to users, and committing it lets
# contributors and the Pages workflow fall back to a known-good
# dataset if the build_static_data.py step ever fails. Daily
# updates do NOT touch these files (they only update
# data/collected/pipeline_output.json), so the diff stays at zero
# between daily runs.

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
