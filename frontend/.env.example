# =============================================================================
# Frontend environment variables - TEMPLATE ONLY
# =============================================================================
#
# SECURITY NOTICE:
#   - DO NOT put real API keys here. The prefix NEXT_PUBLIC_ exposes
#     variables to the browser bundle, so any value here becomes public.
#   - Only put URLs and non-sensitive public configuration.
#   - This file is tracked by git. Copy to .env.local (gitignored) for
#     local development overrides.
# =============================================================================

# Backend API URL. In production, set to your deployed API endpoint.
# Example: NEXT_PUBLIC_API_URL=https://api.api-market.example.com
NEXT_PUBLIC_API_URL=http://localhost:8080
