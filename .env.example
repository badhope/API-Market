# =============================================================================
# API-Market environment variables - TEMPLATE ONLY
# =============================================================================
#
# SECURITY NOTICE:
#   - DO NOT put real API keys, tokens, or passwords in this file.
#   - This file is tracked by git for documentation purposes.
#   - Copy to .env (which is gitignored) and fill in real values locally.
#   - In production, set these via your orchestrator's secret store
#     (Docker secrets, Kubernetes secrets, GitHub Actions secrets, etc.)
# =============================================================================

APP_NAME=API-Market
APP_VERSION=5.0.0
APP_ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8080

DATABASE_URL=sqlite+aiosqlite:///./data/api_market.db

# Redis is optional - if unreachable, the app falls back to in-memory caching.
REDIS_URL=redis://localhost:6379/0

RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_SEARCH_PER_MINUTE=120

# CORS allowed origins. Use specific origins in production, not "*".
# Example for production: CORS_ORIGINS=["https://api-market.example.com"]
CORS_ORIGINS=["*"]

LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional: GitHub token for the data collection pipeline
# -----------------------------------------------------------------------------
# Only used by scripts/pipeline.py and pipeline/collector.py during data
# collection. Leave empty in production deployments that don't run the
# pipeline. GitHub's unauthenticated rate limit (60 req/h) is enough for
# daily updates of a curated subset of sources.
#
# GITHUB_TOKEN=
